# ─────────────────────────────────────────────────────────────────────────────
# Airtable Roadmap Store — Konfiguration (Vorlage)
#
# Benutzung:
#   cp .env.example .env        # dann .env öffnen und AIRTABLE_PAT eintragen
#
# SICHERHEIT — der wichtigste Satz dieses Moduls:
#   • .env enthält dein GEHEIMNIS (den PAT) und steht in .gitignore — NIE committen.
#   • .env.example (diese Datei) enthält nur Platzhalter und WIRD committed.
#   • Base-ID und Table-Name sind KEINE Geheimnisse — sie stehen in jeder
#     Airtable-URL und dürfen ruhig im Repo liegen.
# ─────────────────────────────────────────────────────────────────────────────

# GEHEIMNIS — Personal Access Token, beginnt mit "pat...".
# Erstellen unter https://airtable.com/create/tokens
# Scopes (so wenig wie möglich): data.records:read, data.records:write,
# schema.bases:read — und Zugriff auf GENAU diese eine Base.
AIRTABLE_PAT=pat_REPLACE_ME_xxxxxxxxxxxxxxxx

# Kein Geheimnis — die Ziel-Base (steht in der Airtable-URL als app...).
AIRTABLE_BASE_ID=appcmOMvZGSpCbuSD

# Kein Geheimnis — Tabellenname ODER Tabellen-id (tbl...).
# Die id überlebt Umbenennungen; in Produktion lieber die id verwenden.
AIRTABLE_TABLE_NAME=Roadmap
